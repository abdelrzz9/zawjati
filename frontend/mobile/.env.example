# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
# IMPORTANT: This file is excluded from the app bundle (removed from pubspec.yaml assets).
# Environment variables are only read at compile-time.
#
# For production:
# 1. Use --dart-define=BASE_URL=https://api.production.com
# 2. Or configure CI/CD pipeline to pass env vars
# 3. NEVER commit real secrets to version control
# =============================================================================

# REQUIRED: Base URL for the API
# Development: Use http:// for local development only
# Production: MUST use https://
BASE_URL=http://192.168.100.2:8000

# REQUIRED: Google Sign-In client IDs
GOOGLE_CLIENT_ID=
GOOGLE_SERVER_CLIENT_ID=

# Optional: Custom endpoint paths
GOOGLE_LOGIN_PATH=
WORKSPACE_REGISTER_PATH=
PASSWORD_RESET_REQUEST_PATH=/auth/password-reset/request
PASSWORD_RESET_CONFIRM_PATH=/auth/password-reset/confirm
