# Zawjati Flutter Environment Configuration
# Copy to .env and fill in values

# Backend API URL
BASE_URL=http://localhost:8000

# Google Sign-In (Android)
GOOGLE_CLIENT_ID_ANDROID=your-android-client-id

# Google Sign-In (iOS)
GOOGLE_CLIENT_ID_IOS=your-ios-client-id

# Google Sign-In (Web)
GOOGLE_CLIENT_ID_WEB=your-web-client-id

# Apple Sign-In
APPLE_SERVICE_ID=your-apple-service-id

# Firebase Cloud Messaging
FCM_TOPIC=zawjati_production
