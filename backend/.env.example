# LLM Provider (openai, ollama, openrouter, anthropic, groq, gemini)
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Provider-specific API keys
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Storage
DATABASE_URL=sqlite:///data/zawjati.db
MAX_WORKING_MEMORY=50

# Logging
LOG_LEVEL=INFO
