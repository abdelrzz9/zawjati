# === LLM Provider ===
# Supported: openai, ollama, openrouter, anthropic, groq, gemini
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Provider-specific API keys
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Local models (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# === Storage ===
DATABASE_URL=sqlite:///data/zawjati.db
REDIS_URL=
MEMORY_PROVIDER=memory       # memory, redis, sqlite

# === Context Limits ===
MAX_CONTEXT_TOKENS=8000
MAX_HISTORY_MESSAGES=50
MAX_HISTORY_CHARACTERS=20000

# === Feature Flags ===
STREAMING_ENABLED=true
ENABLE_TOOL_CALLING=true
ENABLE_MEMORY=true

# === Security ===
RATE_LIMIT_PER_MINUTE=60
CORS_ORIGINS=*               # comma-separated origins

# === Observability ===
LOG_LEVEL=INFO
LOG_FORMAT=json              # json or text
METRICS_ENABLED=true
