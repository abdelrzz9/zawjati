# Zawjati Backend Environment Configuration
# Copy to .env and fill in values

# LLM Provider (openai, anthropic, gemini, openrouter, groq, ollama)
LLM_PROVIDER=openai

# API Key for the selected LLM provider
LLM_API_KEY=

# Model name
LLM_MODEL=gpt-4o-mini

# LLM parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Provider-specific keys (only needed for those providers)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Local model settings (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Storage
DATABASE_URL=sqlite:///data/zawjati.db
REDIS_URL=

# Context settings
MAX_CONTEXT_TOKENS=8000
MAX_HISTORY_MESSAGES=50
MAX_HISTORY_CHARACTERS=20000

# Features
STREAMING_ENABLED=true
ENABLE_TOOL_CALLING=true
ENABLE_MEMORY=true

# Security
RATE_LIMIT_PER_MINUTE=60
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_ENABLED=true
